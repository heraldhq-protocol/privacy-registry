{
    "git": {
        "commitMessage": "chore(release): v${version}",
        "tagName": "v${version}",
        "requireCleanWorkingDir": false
    },
    "github": {
        "release": true
    },
    "npm": {
        "publish": false
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": "angular",
            "infile": "CHANGELOG.md"
        },
        "@release-it/bumper": {
            "out": [
                {
                    "file": "programs/herald-privacy-registry/Cargo.toml",
                    "path": "package.version"
                },
                {
                    "file": "Anchor.toml",
                    "path": "toolchain.version"
                }
            ]
        }
    }
}